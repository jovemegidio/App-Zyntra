{
  "expo": {
    "name": "Zyntra",
    "slug": "zyntraaa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "zyntra",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f3f5f9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "br.com.aluforce.zyntra",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir acesso a camera para leitura de codigos de barras e QR codes",
        "NSFaceIDUsageDescription": "Permitir uso do Face ID para login seguro",
        "NSLocationWhenInUseUsageDescription": "Permitir acesso a localizacao para rastreamento de entregas"
      }
    },
    "android": {
      "package": "br.com.aluforce.zyntra",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#090C14"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir $(PRODUCT_NAME) usar Face ID para autenticacao biometrica."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b5a12dc3-0725-43f1-bb1a-f4b837bb76e7"
      }
    },
    "owner": "antoniodevs"
  }
}
