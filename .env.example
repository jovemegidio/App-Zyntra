# =====================================================================
# Zyntra Mobile — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA faça commit do arquivo .env com valores reais.
# =====================================================================

# URL base da API do ERP (sem barra final)
# Expo exige prefixo EXPO_PUBLIC_ para variáveis expostas ao app
EXPO_PUBLIC_API_URL=https://SEU-DOMINIO-REAL.com.br/api

# Slug da empresa (usado para identificação multi-tenant, se necessário)
EXPO_PUBLIC_COMPANY_SLUG=aluforce

# Ambiente atual: development | staging | production
EXPO_PUBLIC_APP_ENV=production
